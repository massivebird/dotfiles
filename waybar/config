{
   // dock | hide | invisible | overlay
   "mode": "dock",
   "ipc": true,

   "layer": "top",
   "position": "top",

   "margin-top": 0,
   "margin-right": 0,
   "margin-bottom": 0,
   "margin-left": 0,

   "modules-left": ["sway/workspaces", "sway/mode"],
   // "modules-center": ["sway/window"],
   "modules-right": ["tray", "pulseaudio", "network", "battery", "custom/jpdate", "clock"],

   "sway/mode": {
      "format": "ΎΒΦΎΕΖ {}"
   },

   "sway/workspaces": {
      "format": "{icon}",
      "disable-scroll": true,
      "format-icons": {
         "1": "ϊ╕Α",
         "2": "ϊ║Ν",
         "3": "ϊ╕Κ",
         "4": "ίδδ",
         "5": "ϊ║Φ",
         "6": "ίΖφ",
         "7": "ϊ╕Δ",
         "8": "ίΖτ",
         "9": "ϊ╣ζ",
         "10": "ίΞΒ"
      }
   },

   "sway/window": {
      "max-length": 80,
      "tooltip": false
   },

   "custom/jpdate": {
      "format": "{}",
      "exec": "~/.config/scripts/jpdate.sh",
      "interval": 60,
      "tooltip": false
   },

   "clock": {
      "format": "{:%H:%M}",
      "tooltip": false
   },

   "battery": {
      "format": "{icon}",
      "format-icons": {
         // Distinguishes full+charging from full+discharging.
         "discharging": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
         "default": ["≤░λε", "≤░ΓΗ", "≤░ΓΘ", "≤░ΓΙ", "≤░λζ", "≤░ΓΚ", "≤░λη", "≤░ΓΛ", "≤░ΓΜ", "≤░ΓΖ"],
      },
      "interval": 5,
      "states": {
         "warning": 25,
         "critical": 10
      },
      "tooltip": true,
      "tooltip-format": "{capacity}%"
   },

   "network": {
      "format": "{icon}",
      // "format-alt": "{ipaddr}/{cidr} {icon}",
      // "format-alt-click": "click-right",
      "format-icons": {
         "wifi": ["≤░νθ", "≤░νλ" ,"≤░νρ"],
         "ethernet": ["≤░ΙΑ"],
         "disconnected": ["≤░νχ"],
         // For disappearing icon issues
         "default": "≤░νχ",
      },
      // https://github.com/ericmurphyxyz/rofi-wifi-menu
      "on-click": "~/bin/rofi-wifi-menu",
      "tooltip": true,
      "tooltip-format": "{}" // Shows network name
   },

   "pulseaudio": {
      "format": "{icon}",
      "format-alt": "{icon} {volume}",
      "format-alt-click": "click-right",
      "format-icons": {
         "headphone": [" ≤░ΜΜ ΎΑο", " ≤░ΜΜ ΎΑπ", " ≤░ΜΜ ΎΑρ", " ≤░ΜΜ ΎΑρ"],
         "headphone-muted": " ≤░ΜΜ Ό╗ρ",
         "default": ["ΎΑο", "ΎΑπ", "ΎΑρ", "ΎΑρ"],
         "default-muted": "Ό╗ρ",
      },
      "scroll-step": 1,
      "on-click": "pulseaudio",
      "tooltip": false
   },

   "custom/spotify": {
      "interval": 5,
      "return-type": "json",
      "exec": "~/.config/waybar/modules/spotify.sh",
      "exec-if": "pgrep spotify",
      "escape": true
   },

   "custom/storage": {
      "format": "{} ΎΓι",
      "format-alt": "{percentage}% ΎΓι",
      "format-alt-click": "click-right",
      "return-type": "json",
      "interval": 60,
      "exec": "~/.config/waybar/modules/storage.sh"
   },

   "backlight": {
      "format": "{icon}",
      "format-alt": "{percent}% {icon}",
      "format-alt-click": "click-right",
      "format-icons": ["ΎΔτ", "Ύβ▓"],
      "on-scroll-down": "light -A 1",
      "on-scroll-up": "light -U 1"
   },

   "custom/weather": {
      "format": "{}",
      "format-alt": "{alt}: {}",
      "format-alt-click": "click-right",
      "interval": 1800,
      "return-type": "json",
      "exec": "~/.config/waybar/modules/weather.sh",
      "exec-if": "ping wttr.in -c1"
   },

   "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
         "activated": "ΎΠΒ",
         "deactivated": "ΎΑμ"
      },
      "tooltip": false
   },

   "custom/mail": {
      "format": "ΎΔι",
      "format-alt": "{alt} ΎΔι",
      "format-alt-click": "click-right",
      "interval": 60,
      "return-type": "json",
      "exec": "~/.config/waybar/modules/mail.py",
      "tooltip": false
   },

   "tray": {
      "icon-size": 18
   }
}
// vim:filetype=jsonc
